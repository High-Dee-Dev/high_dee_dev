{
  "name": "thoughtful-reads-template",
  "version": "1.0.0",
  "description": "A premium, commercial-ready blog and magazine HTML template built with Bootstrap 5",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=3000 --watch=index.html,post.html,category.html,about.html,contact.html,css/,js/,components/",
    "sass:watch": "sass --watch scss:css --style=compressed",
    "sass:build": "sass scss:css --style=compressed",
    "build": "npm run sass:build",
    "serve": "npm run dev",
    "validate": "html-validate *.html",
    "optimize-images": "imagemin assets/images/* --out-dir=assets/images/optimized"
  },
  "keywords": [
    "blog-template",
    "magazine-template",
    "bootstrap-5",
    "html-template",
    "responsive",
    "dark-mode",
    "newsletter",
    "monetization"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "live-server": "^1.2.2",
    "sass": "^1.66.1",
    "html-validate": "^8.1.0",
    "imagemin-cli": "^7.0.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/thoughtful-reads-template"
  },
  "homepage": "https://yourusername.github.io/thoughtful-reads-template"
}